# CardTrack Dashboard - Environment Variables

# Supabase Configuration (get these from your Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# eBay API Configuration (Get these from eBay Developer Portal)
NEXT_PUBLIC_EBAY_CLIENT_ID=your_ebay_client_id_here
EBAY_CLIENT_SECRET=your_ebay_client_secret_here
EBAY_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Vercel Deployment
VERCEL_URL=your-domain-on-vercel.vercel.app

# Environment
NODE_ENV=development
